{
  "name": "minesweeper",
  "private": true,
  "version": "2.4.0",
  "description": "A no-guess Minesweeper game with 50 levels and endless mode",
  "author": "whtanghaonan-wang",
  "repository": "https://github.com/whtanghaonan-wang/minesweeper",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:web": "tsc --noEmit && vite build --base=/minesweeper/",
    "build:desktop": "tsc --noEmit && vite build --base=./",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:pwa": "node scripts/test-pwa-update.mjs",
    "android:init": "tauri android init --ci",
    "android:build": "tauri android build --apk --target aarch64 armv7 x86_64 --ci",
    "android:build:debug": "tauri android build --debug --apk --target aarch64 --ci",
    "tauri": "tauri",
    "version:sync": "node scripts/version.mjs sync",
    "version:check": "node scripts/version.mjs check",
    "version:check:tag": "node scripts/version.mjs check --tag"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.0",
    "jsdom": "^29.1.1",
    "sharp": "^0.35.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0"
  }
}
